# Cursor QA agent daemon (user service)
#
# Install:
#   mkdir -p ~/.config/systemd/user
#   cp systemd/user/qa-agent.service ~/.config/systemd/user/
#   # If cursor-scripts is not in ~/cursor-scripts, edit WorkingDirectory below (or use a drop-in)
#   systemctl --user daemon-reload
#   systemctl --user enable --now qa-agent.service
#
# Logs: ~/.local/log/cursor-agent/qa-agent.log
# Status: systemctl --user status qa-agent.service
# Journal: journalctl --user -u qa-agent.service -f

[Unit]
Description=Cursor QA agent daemon
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
# Must be the directory containing run_agent.py and .env (script resolves paths from here)
WorkingDirectory=%h/cursor-scripts
# Create log directory if missing (- = ignore failure)
ExecStartPre=-/bin/mkdir -p %h/.local/log/cursor-agent
# Use project venv if present (after uv sync), else system python
ExecStart=%h/cursor-scripts/.venv/bin/python run_agent.py --agent qa --daemon
Restart=on-failure
RestartSec=10
# Single log file for stdout and stderr (user-accessible under XDG state)
StandardOutput=append:%h/.local/log/cursor-agent/qa-agent.log
StandardError=append:%h/.local/log/cursor-agent/qa-agent.log

[Install]
WantedBy=default.target
