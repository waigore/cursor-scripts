# Cursor agent runner (run_agent.py). Copy to .env.
# Per-agent settings (project_root, prompt_file, dir_prefix, optional command) live in agents.yaml.
# Create agents.yaml by copying agents.yaml.example; the tool fails if agents.yaml is missing.

# Optional: global agent CLI command.
# If AGENT_CMD is set, it is used for all agents that do not specify a "command"
# field in agents.yaml. The generated prompt argument is appended as the final
# argument unless the token "__PROMPT__" appears as a separate argument, in
# which case it is replaced there.
# AGENT_CMD=agent -p --force --model auto --approve-mcps --output-format stream-json

# Optional: base branch for the project (e.g. PR target)
# BASE_BRANCH=dev

# Optional: daemon mode interval in seconds (default 60). Overridden by per-agent daemon_interval_sec in agents.yaml.
# DAEMON_INTERVAL_SEC=60

# Optional: logging level
# LOG_LEVEL=INFO

# Optional: shared base dirs for all agents (per-agent dir = base + _<dir_prefix> from agents.yaml)
# SESSIONS_DIR=sessions
# TRANSCRIPTS_DIR=transcripts
# MEMORY_BANK_DIR=memory_bank
