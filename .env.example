# Cursor agent runner (run_agent.py). Copy to .env and set PROJECT_ROOT.
# Optional vars below; keys match agents.yaml so you can override per agent.

# Required: path to the project where the agent runs (cwd for agent)
PROJECT_ROOT=

# Optional: agent CLI command (script appends the prompt as final argument)
# AGENT_CMD=agent -p --force --model auto --approve-mcps --output-format stream-json

# Optional: base branch for the project (e.g. PR target)
# BASE_BRANCH=dev

# Optional: daemon mode interval in seconds (default 3600)
# DAEMON_INTERVAL_SEC=3600

# Optional: logging level
# LOG_LEVEL=INFO

# --- Coder agent (run_agent.py -a coder); override defaults from agents.yaml ---
# MEMORY_BANK_DIR=memory_bank
# SESSIONS_DIR=sessions
# TRANSCRIPTS_DIR=transcripts
# PROMPT_FILE=prompts/agent_prompt.md

# --- Reviewer agent (run_agent.py -a reviewer) ---
# REVIEWER_MEMORY_BANK_DIR=memory_bank_reviewer
# REVIEWER_SESSIONS_DIR=sessions_reviewer
# REVIEWER_TRANSCRIPTS_DIR=transcripts_reviewer
# REVIEWER_PROMPT_FILE=prompts/reviewer_prompt.md
