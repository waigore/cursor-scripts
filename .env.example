# Cursor agent runner (run_agent.py). Copy to .env.
# Per-agent settings (project_root, prompt_file, dir_prefix) live in agents.yaml.
# Create agents.yaml by copying agents.yaml.example; the tool fails if agents.yaml is missing.

# Optional: agent CLI command (script appends the prompt as final argument)
# AGENT_CMD=agent -p --force --model auto --approve-mcps --output-format stream-json

# Optional: base branch for the project (e.g. PR target)
# BASE_BRANCH=dev

# Optional: daemon mode interval in seconds (default 3600)
# DAEMON_INTERVAL_SEC=3600

# Optional: logging level
# LOG_LEVEL=INFO

# Optional: shared base dirs for all agents (per-agent dir = base + _<dir_prefix> from agents.yaml)
# SESSIONS_DIR=sessions
# TRANSCRIPTS_DIR=transcripts
# MEMORY_BANK_DIR=memory_bank
