# Required: repo root where the agent runs (cwd for main agent run)
PROJECT_ROOT=

# Optional: base agent CLI command; script appends the prompt as the final argument
AGENT_CMD=agent -p --force --model auto --approve-mcps --output-format stream-json

# Optional: base branch for the agent (compare work against it; PR target)
BASE_BRANCH=dev

# Optional: paths relative to script root (or absolute)
MEMORY_BANK_DIR=memory_bank
SESSIONS_DIR=sessions
TRANSCRIPTS_DIR=transcripts
PROMPT_FILE=prompts/agent_prompt.md
LOG_LEVEL=INFO
