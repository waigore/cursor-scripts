# Copy this file to agents.yaml and set project_root (and any other values) for your environment.
# agents.yaml is not shipped; the tool fails if it is missing.
#
# Agent registry: unique id -> config. Use run_agent.py --agent <id>.
# Per-agent: project_root (required), prompt file, dir_prefix to distinguish this agent's files in shared sessions/transcripts/memory_bank.
# Optional: daemon_interval_sec overrides .env DAEMON_INTERVAL_SEC for this agent (resolution: CLI --interval > agents.yaml > .env).
# Optional: command selects an entry from commands.yaml; when set, it overrides AGENT_CMD/.env and the built-in default.
# Optional: parse_json_logs controls whether this agent's command produces JSON logs that should be parsed by parse_coder_logs.py into markdown transcripts. Defaults to true; set to false to skip parsing and summarization.
# By default agents update their own memory state; set use_summarizer: true to use the shared prompts/summarize_prompt.md.

agents:
  coder:
    name: Coder
    project_root: ""  # required: set to the project path where this agent runs
    default_prompt_file: prompts/agent_prompt.md
    dir_prefix: ""
    # Optional: command id defined in commands.yaml under commands: <id>: ...
    # If omitted, the AGENT_CMD env var or the default agent command is used.
    # command: default
    # parse_json_logs: true  # set to false to skip parse_coder_logs.py and summarizer
    daemon_interval_sec: 600  # 10 minutes; overrides .env DAEMON_INTERVAL_SEC
    use_summarizer: false

  # GDD coder: generic agent for GDD-driven development (see systemd/user/gdd-coder-agent.service)
  gdd-coder:
    name: GDD Coder
    project_root: ""  # required: set to the project path where this agent runs
    default_prompt_file: prompts/generic_agent_prompt.md
    dir_prefix: "gddcoder"
    # command: default
    # parse_json_logs: true
    daemon_interval_sec: 600  # 10 minutes
    use_summarizer: false
    file_list: |
      SPEC/project/agentic-gdd-scenario-coverage.md

  reviewer:
    name: Reviewer
    project_root: ""  # required: set to the project path where this agent runs
    default_prompt_file: prompts/reviewer_prompt.md
    dir_prefix: "reviewer"
    # command: default
    # parse_json_logs: true
    daemon_interval_sec: 1800  # 30 minutes; overrides .env DAEMON_INTERVAL_SEC
    use_summarizer: false

  verifier:
    name: Verifier
    project_root: ""  # required: set to the project path where this agent runs
    default_prompt_file: prompts/verifier_prompt.md
    dir_prefix: "verifier"
    # command: default
    # parse_json_logs: true
    daemon_interval_sec: 300  # 5 minutes; handles and verifies open issues raised by the reviewer
    use_summarizer: false

  generic:
    name: Generic
    project_root: ""  # required: set to the project path where this agent runs
    default_prompt_file: prompts/generic_agent_prompt.md
    dir_prefix: "generic"
    # command: default
    # parse_json_logs: true
    daemon_interval_sec: 900  # 15 minutes; example interval for a generic agent
    use_summarizer: false
    # Optional: list of files (relative to project_root) that the generic agent
    # should read for additional context. This string is substituted into
    # {{FILE_LIST}} in prompts/generic_agent_prompt.md.
    file_list: |
      SPEC/requirements.md
      README.md
      src/config/feature_flags.yaml
